    "installer",
    "scaffold",
    "template",
    "project-setup",
    "developer-tools"
  ],
  "homepage": "https://github.com/ihdatech/coffee-installer#readme",
  "bugs": {
    "url": "https://github.com/ihdatech/coffee-installer/issues"
  },
  "license": "MIT",
  "author": "ihdatech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ihdatech/coffee-installer.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "coffee-installer": "index.js",
    "coffee": "index.js"
  },
